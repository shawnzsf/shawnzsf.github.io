<section class="archive-section">
  
  <div class="section-header">
    <h2 class="section-title">Blog <span class="jp">記録</span></h2>
  </div>

  <% page.posts.each(function(post) { %>
    <article class="cv-item archive-item">
      <div class="cv-date">
        <%= date(post.date, 'YYYY.MM.DD') %>
      </div>
      
      <div class="cv-content">
        <h3>
          <a href="<%- url_for(post.path) %>"><%= post.title %></a>
        </h3>
        <% if (post.tags && post.tags.length){ %>
          <div class="role">
            <%= post.tags.map(t => t.name).join(' · ') %>
          </div>
        <% } %>
        <p>
          <% if(post.excerpt) { %>
            <%- strip_html(post.excerpt).substring(0, 200) %>
            <% if(strip_html(post.excerpt).length > 200) { %>...<% } %>
          <% } else { %>
            <%= strip_html(post.content).substring(0, 200) %>...
          <% } %>
        </p>
      </div>
    </article>
  <% }) %>
  
  <!-- Pagination -->
  <% if (page.total > 1){ %>
    <nav class="pagination">
      <%- paginator({
        prev_text: '← Prev',
        next_text: 'Next →',
        escape: false
      }) %>
    </nav>
  <% } %>
  
</section>
