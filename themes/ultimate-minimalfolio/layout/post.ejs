<div class="post-container">
  
  <!-- 1. The Article Content -->
  <article class="blog-article">
    <header class="post-header">
      <div class="post-meta">
        <span class="jp-date"><%= date(page.date, 'YYYY/MM/DD') %></span>
        <% if(page.categories && page.categories.length) { %>
           <span class="separator">/</span> 
           <span class="category"><%= page.categories.data[0].name %></span>
        <% } %>
      </div>
      <h1 class="post-title"><%= page.title %></h1>
    </header>

    <div class="markdown-body">
      <%- page.content %>
    </div>
    
    <!-- Optional: Footer of the post -->
    <div style="margin-top: 60px; padding-top: 20px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.8rem; font-style: italic;">
      <p>Thanks for reading.</p>
    </div>
  </article>

  <!-- 2. The Right-Side Menu (TOC) -->
  <aside class="post-toc">
    <div class="toc-wrapper">
      <div class="toc-header">
        On this page
      </div>
      <%- toc(page.content, {list_number: false}) %>
    </div>
  </aside>

</div>

<!-- Improved Highlight Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tocLinks = document.querySelectorAll('.post-toc a');
    const sections = document.querySelectorAll('.markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4');
    
    const observerOptions = {
      root: null,
      rootMargin: '-100px 0px -60% 0px', 
      // This margin is key: it effectively draws a line near the top of the screen.
      // An element only "intersects" when it crosses this line.
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          
          // Remove active class from all
          tocLinks.forEach(link => link.classList.remove('active'));
          
          // Add active class to current
          // We must decodeURI because Hexo might encode Japanese/special chars in IDs
          const activeLink = document.querySelector(`.post-toc a[href="#${decodeURI(id)}"]`);
          if (activeLink) {
            activeLink.classList.add('active');
          }
        }
      });
    }, observerOptions);

    sections.forEach((section) => {
      observer.observe(section);
    });
  });
</script>